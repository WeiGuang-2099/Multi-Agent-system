FROM python:3.11-slim

# Security: minimal packages only. No gcc (prevents native exploit compilation),
# no requests (sandbox has no network access via --network none).
RUN pip install --no-cache-dir \
    numpy>=1.26 \
    pandas>=2.2 \
    matplotlib>=3.8

WORKDIR /sandbox

RUN useradd --create-home sandbox_user
USER sandbox_user

ENTRYPOINT ["python", "/sandbox/code.py"]
