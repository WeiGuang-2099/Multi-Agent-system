# LLM Configuration
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# Per-agent model overrides (optional)
# SEARCH_AGENT_MODEL=claude-sonnet-4-20250514
# CODE_AGENT_MODEL=claude-sonnet-4-20250514
# WRITER_AGENT_MODEL=claude-sonnet-4-20250514

# API Keys
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_API_KEY=xxx

# Tavily Search
TAVILY_API_KEY=tvly-xxx

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=research_assistant
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_password

# LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_xxx
LANGSMITH_PROJECT=multi-agent-research-assistant

# A2A Agent Ports
SUPERVISOR_PORT=8001
SEARCH_AGENT_PORT=8002
CODE_AGENT_PORT=8003
WRITER_AGENT_PORT=8004

# Streamlit
STREAMLIT_PORT=8501

# Code Sandbox
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1
SANDBOX_TIMEOUT=30
