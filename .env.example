# LLM Configuration
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# Per-agent model overrides (optional)
# SEARCH_AGENT_MODEL=gpt-4o
# CODE_AGENT_MODEL=gpt-4o
# WRITER_AGENT_MODEL=gpt-4o

# API Keys
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_API_KEY=xxx

# Tavily Search
TAVILY_API_KEY=tvly-xxx

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=research_assistant
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_password

# LangSmith Tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_pt_xxx
LANGSMITH_PROJECT=multi-agent-research-assistant

# A2A Agent Ports
SUPERVISOR_PORT=8001
SEARCH_AGENT_PORT=8002
CODE_AGENT_PORT=8003
WRITER_AGENT_PORT=8004

# Streamlit
STREAMLIT_PORT=8501

# Code Sandbox
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1
SANDBOX_TIMEOUT=30

# A2A Client (for distributed mode)
SUPERVISOR_URL=http://localhost:8001

# --- Optional features (all off by default) ---

# Human-in-the-Loop: pause after supervisor plan for user approval
HITL_ENABLED=false
HITL_MAX_ROUNDS=1

# Reflection: Critic agent reviews the report and triggers bounded revisions
CRITIC_ENABLED=false
CRITIC_MAX_ROUNDS=2

# RAG: Retrieval agent + Chroma knowledge base
RAG_ENABLED=false
RAG_PERSIST_DIR=data/chroma
RAG_COLLECTION=research_kb

# Cost control (OpenAI provider only): cheap model for routing/critic,
# strong model for writer. Per-agent *_MODEL overrides still win.
DAILY_TOKEN_BUDGET=0
CHEAP_MODEL=gpt-4o-mini
STRONG_MODEL=gpt-4o

# Observability
# LOG_JSON=true|false  (default true; set false for readable console logs)
# LOG_LEVEL=INFO
# METRICS_LOG=logs/metrics.jsonl